# production
DOTENV_VAULT_PRODUCTION=""
DOTENV_VAULT_PRODUCTION_VERSION=8

# development
DOTENV_VAULT_DEVELOPMENT=""
DOTENV_VAULT_DEVELOPMENT_VERSION=6

# testing
DOTENV_VAULT_TESTING=""
DOTENV_VAULT_TESTING_VERSION=8

# staging
DOTENV_VAULT_STAGING=""
DOTENV_VAULT_STAGING_VERSION=8

#/----------------settings/metadata-----------------/
DOTENV_VAULT="vlt_7cdb3918676826247ec0d4e4f0dfa64d9e1d2b33b983b346f3e16f1a902b95bf"
DOTENV_API_URL="https://vault.dotenv.org"
DOTENV_CLI="npx dotenv-vault@latest"
